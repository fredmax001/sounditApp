# Sound It Platform - Environment Configuration Example
# ======================================================
# Copy this file to .env (local dev) or .env.production (production)
# and fill in your actual API keys and secrets.

# ============================================
# App Settings
# ============================================
APP_NAME="Sound It API"
DEBUG=True  # Set to False in production
SECRET_KEY="your-secret-key-here"  # Generate with: openssl rand -hex 32
BASE_URL="http://localhost:8000"  # Change to https://sounditent.com in production

# ============================================
# Database
# ============================================
# SQLite (easy for local dev):
DATABASE_URL="sqlite:///./soundit_local.db"
# PostgreSQL (recommended for production):
# DATABASE_URL="postgresql://user:password@localhost:5432/soundit"

# ============================================
# Redis (Optional - for caching/sessions)
# ============================================
REDIS_URL="redis://localhost:6379/0"

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET="your-jwt-secret-here"  # Generate with: openssl rand -hex 32
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ============================================
# SendGrid (Email) - Get from https://app.sendgrid.com/settings/api_keys
# ============================================
SENDGRID_API_KEY=""  # Your SendGrid API key
SENDGRID_FROM_EMAIL="noreply@sounditent.com"

# ============================================
# Twilio (SMS) - Get from https://www.twilio.com/console
# ============================================
TWILIO_ACCOUNT_SID=""  # Your Twilio Account SID
TWILIO_AUTH_TOKEN=""   # Your Twilio Auth Token
TWILIO_PHONE_NUMBER="" # Your Twilio phone number (e.g., +1234567890)
TWILIO_VERIFY_SERVICE_SID=""  # Twilio Verify Service SID (optional)

# ============================================
# Google OAuth - Get from https://console.cloud.google.com/apis/credentials
# ============================================
GOOGLE_CLIENT_ID=""     # Your Google OAuth Client ID
GOOGLE_CLIENT_SECRET="" # Your Google OAuth Client Secret
GOOGLE_REDIRECT_URI="http://localhost:8000/auth/google/callback"  # Change for production

# ============================================
# Stripe (Payments) - Get from https://dashboard.stripe.com/apikeys
# ============================================
STRIPE_SECRET_KEY=""      # Your Stripe Secret Key (sk_...)
STRIPE_WEBHOOK_SECRET=""  # Your Stripe Webhook Secret (whsec_...)
STRIPE_PUBLISHABLE_KEY="" # Your Stripe Publishable Key (pk_...)

# ============================================
# Yoopay (Chinese Payment Gateway)
# ============================================
YOOPAY_API_KEY=""
YOOPAY_SELLER_EMAIL=""
YOOPAY_PAYMENT_URL="https://yoopay.cn/tc/603316601"
YOOPAY_COMPANY_ID="603316601"
YOOPAY_QR_IMAGE_PATH="/static/yoopay_qr_code.jpg"

# ============================================
# WeChat Pay (Chinese Market)
# ============================================
WECHAT_APP_ID=""      # Your WeChat App ID
WECHAT_APP_SECRET=""  # Your WeChat App Secret
WECHAT_MCH_ID=""      # Your WeChat Merchant ID
WECHAT_API_KEY=""     # Your WeChat API Key

# ============================================
# AWS S3 (File Storage) - Get from https://console.aws.amazon.com/iam/
# ============================================
AWS_ACCESS_KEY_ID=""       # Your AWS Access Key ID
AWS_SECRET_ACCESS_KEY=""   # Your AWS Secret Access Key
AWS_S3_BUCKET="sound-it-uploads"
AWS_REGION="us-east-1"
AWS_S3_ENDPOINT=""         # Optional: for S3-compatible services
AWS_CLOUDFRONT_URL=""      # Optional: CloudFront CDN URL

# ============================================
# hearthis.at / Music API
# ============================================
HEARTHIS_API_KEY=""                   # hearthis.at API key (if available)
HEARTHIS_API_URL="https://hearthis.at/api/v1/"
HEARTHIS_USERNAME="djfredmax"         # Your hearthis.at username

# RapidAPI (for hearthis.at access) - Get from https://rapidapi.com/developer
RAPIDAPI_KEY=""                       # Your RapidAPI key
RAPIDAPI_HOST="hearthis-at.p.rapidapi.com"

# ============================================
# Security Settings (Production)
# ============================================
# Comma-separated lists
ALLOWED_HOSTS="localhost,127.0.0.1,0.0.0.0"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:4173"

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# File Upload Limits
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# ============================================
# Monitoring & Logging
# ============================================
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR
LOG_FILE="logs/app.log"

# Sentry Error Tracking (Optional) - Get from https://sentry.io/
SENTRY_DSN=""

# Error Webhook URL (Optional - for notifications)
ERROR_WEBHOOK_URL=""

# ============================================
# Platform Settings
# ============================================
DEFAULT_CURRENCY="CNY"
TIMEZONE="Asia/Shanghai"
PLATFORM_COMMISSION_RATE=0.10  # 10% commission
MIN_PAYOUT_AMOUNT=100.00

# ============================================
# OTP Settings
# ============================================
OTP_EXPIRATION_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_MINUTES=15
